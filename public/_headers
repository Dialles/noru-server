# Headers aplicados às respostas de assets estáticos pelo Cloudflare Workers.
# As respostas de /api/* são geradas pelo Worker (src/server/http.ts) e definem os próprios headers.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; manifest-src 'self'

# Assets versionáveis: cache longo e imutável.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/admin/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# HTML sempre revalidado para refletir mudanças de deploy.
/*.html
  Cache-Control: no-cache
